# ============================================
# INDMoney Weekly Pulse — Environment Variables
# ============================================
# Copy this file to .env and fill in your values
# Never commit the .env file to version control

# Groq API (Theme Generation & Classification)
GROQ_API_KEY=your_groq_api_key_here

# Google Gemini API (Pulse Summaries & Email Polish)
GEMINI_API_KEY=your_gemini_api_key_here

# Gmail Credentials (SMTP Delivery)
# Generate an App Password at: https://myaccount.google.com/apppasswords
EMAIL_ADDRESS=your_email@gmail.com
EMAIL_APP_PASSWORD=your_gmail_app_password_here

# Optional: Change the port for the Streamlit dashboard
PORT=8501

# ==========================================
# Phase 10B: Google Docs MCP Setup
# ==========================================

# Google Docs target for appending the weekly combined json
# Example: If your URL is https://docs.google.com/document/d/1X2Y3Z4W5V6U7T8S/edit
# Then your ID is: 1X2Y3Z4W5V6U7T8S
GOOGLE_DOC_ID=your_google_doc_id_here

# MCP Server Execution Configuration
# The Python MCP Client needs to invoke the Google Docs MCP Server via STDIO
MCP_GOOGLE_DOCS_SERVER_CMD=npx
MCP_GOOGLE_DOCS_SERVER_ARGS=-y @anthropic/mcp-google-docs

# Path to the Google Cloud Service Account JSON credentials file
# Required for the MCP server to authenticate with Google APIs
GOOGLE_DOCS_CREDENTIALS="C:\Users\Gayathri\.gemini\antigravity\scratch\GenAIBootcamp_Milestone2\weekly-pulse-review-indmoney-93ca6c81d8d6.json"
