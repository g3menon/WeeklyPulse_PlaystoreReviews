# ============================================
# INDMoney Weekly Pulse — .gitignore
# ============================================

# Environment variables (NEVER commit)
.env

# Runtime data outputs
data/*
!data/weekly_pulse.json
!data/reviews_classified.json
!data/fee_explanation.json
!data/email_draft.html

# Python
__pycache__/
*.pyc
*.pyo
*.pyd
*.egg-info/
dist/
build/
venv/
.venv/

# IDE
.vscode/
.idea/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Docker
*.log
